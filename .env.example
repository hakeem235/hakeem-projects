# EmailJS — used server-side by app/api/contact/route.ts.
# Copy this file to .env.local and fill in your real values (do NOT commit .env.local).
# Keep these server-only — do not prefix with NEXT_PUBLIC_, or they ship to the browser.
EMAILJS_SERVICE_ID=your_service_id
EMAILJS_TEMPLATE_ID=your_template_id
EMAILJS_PUBLIC_KEY=your_public_key
EMAILJS_PRIVATE_KEY=your_private_key
